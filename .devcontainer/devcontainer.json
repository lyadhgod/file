{
    "image": "node:25.8.0-bookworm",
    "initializeCommand": "PROOT=$(pwd) && cd $PROOT/my-web && docker compose up -d",
    "postCreateCommand": "PROOT=$(pwd) && cd $PROOT/my-web && npm install ; cd $PROOT/my-app && npm install",
    "customizations": {
        "vscode": {
            "settings": {
                "chat.autoReply": true,
                "chat.tools.global.autoApprove": true
            }
        }
    }
}